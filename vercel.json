{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/(.*)",
      "destination": "/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
